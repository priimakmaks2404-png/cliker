#:import from_hex kivy.utils.get_color_from_hex
#:import to_rgba kivy.utils.rgba
#:import colormap kivy.utils.colormap

#:set main_color '#ef852e'
#:set main_color_dark "#c96e24" 


<Widget>:
    font_name: 'C:/Windows/Fonts/segoeui.ttf'


<ButtonMenu@Button>: 
    font_size: "56sp"
    bold: True 
    background_color: 0, 0, 0, 0
    size_hint: None, None
    size: dp(240), dp(60)
    pos_hint: {"center_x": 0.5}

    canvas.before:
        Color:
            rgba: colormap['white']
        RoundedRectangle:
			size: self.size
			pos: self.pos
			radius: [self.font_size]
		Color:
			rgba: from_hex(main_color) if self.state == 'normal' else from_hex(main_color_dark)
		RoundedRectangle:
			size: self.size[0] - dp(6), self.size[1] - dp(6)
			pos: self.pos[0] + dp(3), self.pos[1] + dp(3)
			radius: [self.font_size]
 

<ButtonIcon@ButtonMenu>: 
    font_name: 'assets/typicons.ttf'
    size: dp(64), dp(64)

<Menu>:
    BoxLayout:
        orientation: "vertical" 
        padding: "30dp"
        spacing: "20dp"   

        canvas:
            Rectangle:
                source: 'assets/images/e1338fb4-2c9b-4539-992d-4e96cce7b215.jpg'
                size: dp(750), self.size[1]
                pos: self.center_x - dp(750) / 2, self.y

        Widget:
            size_hint_y: 0.45

        ButtonMenu:
            text: " PLAY "
            pos_hint: {"center_x": 0.5}

            on_press: 
                root.manager.current = "game"
                root.manager.transition.direction = "left"

        Widget:
            size_hint_y: 0.10

        BoxLayout:
            size_hint_y: 0.15

            # Button "Settings" 
            ButtonIcon: 
                text: "\uE04F" 
                on_press:
                    root.go_settings() 

            Widget:

            # Button "Exit" 
            ButtonIcon: 
                text: "\uE121" 
                on_press:
                    app.stop() 


<Settings>:
    BoxLayout:
        orientation: "vertical" 
        padding: "30dp"
        spacing: "20dp"  

        Label:
            text: "Settings"
            font_size: "40sp"
            size_hint_y: 0.15
        
        BoxLayout:
            orientation: "vertical"
            size_hint_y: 0.3
            spacing: "10dp"
            
            Label:
                text: "Volume"
                font_size: "28sp"
                size_hint_y: 0.3
            
            BoxLayout:
                size_hint_y: 0.7
                spacing: "10dp"
                
                Slider:
                    id: volume_slider
                    min: 0
                    max: 1
                    value: app.volume
                    on_value: app.volume = self.value
                
                Label:
                    text: str(int(app.volume * 100)) + "%"
                    font_size: "24sp"
                    size_hint_x: 0.2
        
        Widget:
            size_hint_y: 0.4
            
        ButtonMenu:
            text: "Back"
            on_press:
                root.go_back()

<Market>:
    BoxLayout:
        orientation: "vertical"
        padding: "30dp"
        spacing: "20dp"

        canvas:
            Rectangle:
                source: 'assets/images/43e96a23-4a8e-446b-bba2-a1c1ece253a2.png'
                pos: self.pos
                size: self.size

        Label:
            text: "Market"
            font_size: "30sp"
            color: colormap['white']
            size_hint_y: 0.12

        Label:
            text: "Clicks: " + str(app.total_clicks)
            font_size: "18sp"
            color: colormap['white']
            size_hint_y: None
            height: dp(30)

        BoxLayout:
            orientation: "vertical"
            spacing: "14dp"
            size_hint_y: 0.68
            pos_hint: {"x": -0.03, "top": 1.10}

            ButtonMenu:
                text: "Кнопка 2\n+3 клика\n50 кликов"
                font_size: "18sp"
                color: colormap['white']
                pos_hint: {"x": 0.02}
                disabled: app.total_clicks < 50
                opacity: 1 if app.total_clicks >= 50 else 0.75
                on_press: root.set_click_power(3)

            ButtonMenu:
                text: "Кнопка 3\n+5 кликов\n100 кликов"
                font_size: "18sp"
                color: colormap['white']
                pos_hint: {"x": 0.02}
                disabled: app.total_clicks < 100
                opacity: 1 if app.total_clicks >= 100 else 0.75
                on_press: root.set_click_power(5)

            ButtonMenu:
                text: "Кнопка 4\n+7 кликов\n150 кликов"
                font_size: "18sp"
                color: colormap['white']
                pos_hint: {"x": 0.02}
                disabled: app.total_clicks < 150
                opacity: 1 if app.total_clicks >= 150 else 0.75
                on_press: root.set_click_power(7)

            ButtonMenu:
                text: "Кнопка 5\n+9 кликов\n250 кликов"
                font_size: "18sp"
                color: colormap['white']
                pos_hint: {"x": 0.02}
                disabled: app.total_clicks < 250
                opacity: 1 if app.total_clicks >= 250 else 0.75
                on_press: root.set_click_power(9)

            ButtonMenu:
                text: "Кнопка 6\n+11 кликов\n400 кликов"
                font_size: "18sp"
                color: colormap['white']
                pos_hint: {"x": 0.02}
                disabled: app.total_clicks < 400
                opacity: 1 if app.total_clicks >= 400 else 0.75
                on_press: root.set_click_power(11)

        ButtonMenu:
            text: "Back"
            on_press:
                root.go_back()

<RotatedImage>:
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            axis: 0, 0, 1
            origin: self.center
    canvas.after:
        PopMatrix


<Fish>:
    source: 'assets/images/be3dbadd-9ae5-4882-a7c1-db19071013d7.png'
    size_hint: None, None
    size: dp(200), dp(200)
    allow_stretch: True
    opacity: 0
    

<Game>:
    BoxLayout:
        orientation: "vertical" 
        padding: "30dp"
        spacing: "20dp"   

        canvas:
            Rectangle:
                source: 'assets/images/a41ed0e3-8338-44b5-ade5-ab200dcbbff3.jpg'
                pos: self.pos
                size: self.size

        # Верхнє меню
        BoxLayout:
            size_hint_y: 0.12

            # Текстовий напис "Бали"
            Label:
                text: str(root.score)
                font_size: '56sp'
                size_hint_x: 0.8
                pos_hint: {'center_x': 1}

            # Кнопка-іконка "Дім"
            ButtonIcon: 
                text: '\uE08A' 
                on_press: root.go_home()

            # Кнопка-іконка "Налаштування"
            ButtonIcon:
                font_name: 'assets/typicons.ttf'
                text: '\uE04F' 
                size_hint_x: None
                font_size: '38sp'
                on_press: root.go_settings()

        # Ігрова область
        FloatLayout:
            size_hint_y: 0.76
            id: game_window

            Fish:
                id: fish
                center: root.center

            Label:
                id: level_complete
                text: '    Level\ncomplete!'
                color: from_hex('#12F3AF')#colormap['lawngreen']
                font_size: '50sp'
                size_hint_y: None
                height: self.texture_size[1]
                x: root.width / 2 - self.width / 2
                y: root.height / 2 - self.height / 2 + dp(100)
                opacity: 0

            Label:
                text: 'Пройдено 5 уровней: ' + str(app.completed_full_runs)
                font_size: '24sp'
                color: colormap['white']
                size_hint: None, None
                size: self.texture_size
                pos_hint: {'x': 0.02, 'top': 0.98}
                opacity: 1 if app.completed_full_runs > 0 else 0

            BoxLayout:
                id: game_over_panel
                orientation: 'vertical'
                size_hint: None, None
                size: dp(330), dp(220)
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                spacing: '14dp'
                opacity: 0
                disabled: True

                ButtonMenu:
                    text: 'Restart'
                    on_press: root.restart_game()

        # Нижнє меню
        BoxLayout:
            size_hint_y: 0.12
            spacing: '10dp'

            Widget:

            ButtonMenu:
                text: 'Market'
                font_size: '22sp'
                on_press: root.go_market()

            Widget:

        # Icon
        # Label:
        #     font_name: 'assets/typicons.ttf'
        #     text: '\uE08A' 
        #     font_size: '56sp'

        